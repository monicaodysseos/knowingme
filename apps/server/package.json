{
  "name": "@ksero-se/server",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --alias:@ksero-se/types=../../packages/types/src/index.ts --external:bufferutil --external:utf-8-validate --external:hiredis --outfile=dist/index.js",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ksero-se/types": "*",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "xstate": "^5.18.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.21.5",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
